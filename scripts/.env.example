# Lokaal draaien: cp .env.example .env en vul aan, dan `npm run generate`.
# In GitHub Actions worden deze als repo-secrets gezet (zie README.md).

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Provider: 'gemini' (default) of 'anthropic'.
LLM_PROVIDER=gemini

# Vul enkel de key in van de provider die je gebruikt.
GEMINI_API_KEY=AIza...                 # van https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY=sk-ant-...         # van https://console.anthropic.com

# Optioneel — override default model (gemini-2.5-flash / claude-haiku-4-5-20251001)
# MODEL=gemini-2.5-pro
# MODEL=claude-sonnet-4-6

# Optioneel — limiteer aantal aanvragen per run (default 10)
# MAX_REQUESTS=10
